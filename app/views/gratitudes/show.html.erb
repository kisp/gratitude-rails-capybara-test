<div class="card shadow-sm">
  <div class="card-body">
    <h2 class="card-title"><%= @gratitude.content %></h2>
    <p class="text-muted"><%= @gratitude.entry_date.strftime("%B %d, %Y") %></p>
  </div>
</div>

<div class="mt-3">
  <%= link_to "Edit", edit_gratitude_path(@gratitude), class: "btn btn-outline-secondary me-1" %>
  <%= link_to "Back to gratitudes", gratitudes_path, class: "btn btn-outline-primary me-1" %>
  <%= button_to "Delete", @gratitude, method: :delete, class: "btn btn-outline-danger" %>
</div>
